BETBOT_ODDS_SUBSCRIBE_MESSAGES=["[\"CONNECT\\ntoken:Bearer null\\naccept-version:1.1,1.0\\nheart-beat:5000,10000\\n\\n\\u0000\"]","[\"SUBSCRIBE\\nid:sub-0\\ndestination:/topic/betfair_match_odds_update/{eventId}/{marketId}\\n\\n\\u0000\"]"]
BETBOT_ODDS_ADJUSTMENT=0.05

