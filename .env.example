BETBOT_REFERER=https://www.crypto247.club/
BETBOT_ORIGIN=https://www.crypto247.club
BETBOT_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/141.0.0.0 Safari/537.36
BETBOT_ACCEPT_LANGUAGE=en-GB,en-US;q=0.9,en;q=0.8,hi;q=0.7

BETBOT_SPORT_ID=4
BETBOT_COMPETITION_ID=*
